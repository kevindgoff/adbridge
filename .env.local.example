POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=adbridge
POSTGRES_USER=adbridge
POSTGRES_PASSWORD=adbridge

# Database backend: "postgres" (default) or "sqlite"
DB_BACKEND=postgres

# SQLite file path (only used when DB_BACKEND=sqlite)
SQLITE_PATH=adbridge.db

# Optional – leave blank to disable API key authentication
API_KEY=
